# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=asistencia_db

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Biometric reader
BIOMETRIC_MODE=sdk
BIOMETRIC_ADAPTER_MODULE=./src/services/biometricAdapter.js
BIOMETRIC_DEVICE_ID=reader-01
BIOMETRIC_TIMEOUT_MS=10000
